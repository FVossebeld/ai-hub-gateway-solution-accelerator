<policies>
    <inbound>
        <base />
        <!-- Rate limiting -->
        <rate-limit calls="100" renewal-period="60" />
        
        <!-- Use the Google Search backend -->
        <set-backend-service backend-id="google-search-backend" />
        
        <!-- Inject Google API Key from Named Values -->
        <set-query-parameter name="key" exists-action="override">
            <value>{{google-search-api-key}}</value>
        </set-query-parameter>
        
        <!-- Inject default CX (Search Engine ID) if not provided by caller -->
        <set-query-parameter name="cx" exists-action="skip">
            <value>{{google-search-engine-id}}</value>
        </set-query-parameter>
        
        <!-- Validate required parameters -->
        <choose>
            <when condition="@(context.Request.Url.Query.GetValueOrDefault("q", "") == "")">
                <return-response>
                    <set-status code="400" reason="Bad Request" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>@{
                        return new JObject(
                            new JProperty("error", "Missing required parameter 'q' (search query)")
                        ).ToString();
                    }</set-body>
                </return-response>
            </when>
        </choose>
        
        <!-- Log request details -->
        <trace source="google-search-api" severity="information">
            <message>@($"Search Query: {context.Request.Url.Query.GetValueOrDefault("q", "")}")</message>
        </trace>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
        
        <!-- Remove any sensitive headers from response -->
        <set-header name="X-Google-API-Key" exists-action="delete" />
        
        <!-- Add custom headers -->
        <set-header name="X-Powered-By" exists-action="override">
            <value>Citadel AI Gateway</value>
        </set-header>
    </outbound>
    <on-error>
        <base />
        
        <!-- Custom error handling -->
        <choose>
            <when condition="@(context.LastError.Reason == "Unauthorized")">
                <return-response>
                    <set-status code="401" reason="Unauthorized" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>@{
                        return new JObject(
                            new JProperty("error", "Invalid Google API credentials")
                        ).ToString();
                    }</set-body>
                </return-response>
            </when>
        </choose>
    </on-error>
</policies>
